generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

enum ImportSource {
  USA
  CANADA
  CHINA
  LOCAL
}

enum VehicleStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum RentalCategory {
  ECONOMY
  SEDAN
  SUV
  LUXURY
  VANS_AND_BUSES
}

enum RequestStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Vehicle {
  id           String        @id @default(cuid())
  title        String
  make         String
  model        String
  year         Int
  price        Int
  mileage      Int           @default(0)
  fuelType     String        @default("Petrol")
  transmission String        @default("Automatic")
  bodyType     String        @default("Sedan")
  color        String        @default("Black")
  engine       String        @default("")
  description   String        @db.Text
  images       String        @db.Text // JSON array of urls
  importSource ImportSource  @default(USA)
  status       VehicleStatus @default(AVAILABLE)
  featured     Boolean       @default(false)
  createdAt    DateTime      @default(now())

  inquiries SalesInquiry[]
}

model RentalVehicle {
  id           String         @id @default(cuid())
  name         String
  category     RentalCategory @default(ECONOMY)
  seats        Int            @default(5)
  transmission String         @default("Automatic")
  image        String         @db.Text
  dailyRate    Int
  weeklyRate   Int
  monthlyRate  Int
  available    Boolean        @default(true)
  createdAt    DateTime       @default(now())

  bookings RentalBooking[]
}

model SalesInquiry {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String
  message   String        @db.Text
  vehicleId String?
  status    RequestStatus @default(NEW)
  createdAt DateTime      @default(now())

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
}

model RentalBooking {
  id              String        @id @default(cuid())
  name            String
  email           String
  phone           String
  rentalVehicleId String?
  category        String
  startDate       DateTime
  endDate         DateTime
  pricingPlan     String        @default("Daily")
  delivery        Boolean       @default(false)
  deliveryAddress String?
  notes           String        @db.Text
  status          RequestStatus @default(NEW)
  createdAt       DateTime      @default(now())

  rentalVehicle RentalVehicle? @relation(fields: [rentalVehicleId], references: [id])

  @@index([rentalVehicleId])
}

model InsuranceInquiry {
  id            String        @id @default(cuid())
  name          String
  email         String
  phone         String
  coverageType  String
  vehicleValue  String?
  vehicleDetail String?
  message       String        @db.Text
  status        RequestStatus @default(NEW)
  createdAt     DateTime      @default(now())
}

model LicensingRequest {
  id          String        @id @default(cuid())
  name        String
  email       String
  phone       String
  serviceType String
  vehicleInfo String?
  message     String        @db.Text
  status      RequestStatus @default(NEW)
  createdAt   DateTime      @default(now())
}

model TrackingInquiry {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String
  plan      String
  fleetSize String?
  message   String        @db.Text
  status    RequestStatus @default(NEW)
  createdAt DateTime      @default(now())
}
